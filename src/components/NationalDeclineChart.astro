---
import data from '../data/crisis-nacional.json';
---

<div class="nd-wrap reveal">
  <div class="nd-card">
    <div class="nd-header">
      <div>
        <h4 class="nd-title">Caída de hectáreas plantadas a nivel nacional</h4>
        <span class="nd-sub">Hectáreas · 2010-2024</span>
      </div>
      <div class="nd-headline-stat">
        <span class="nd-headline-num">-31,56%</span>
        <span class="nd-headline-label">en 14 años</span>
      </div>
    </div>

    <div class="nd-canvas-container">
      <canvas id="ndChart" aria-label="Evolución de las hectáreas plantadas de tabaco en Argentina entre 2010 y 2024"></canvas>
    </div>

    <div class="nd-stats">
      <div class="nd-stat">
        <span class="nd-stat-num">26.000</span>
        <span class="nd-stat-label">hectáreas perdidas</span>
      </div>
      <div class="nd-stat">
        <span class="nd-stat-num">-38,7%</span>
        <span class="nd-stat-label">caída de producción</span>
      </div>
      <div class="nd-stat">
        <span class="nd-stat-num">+82%</span>
        <span class="nd-stat-label">precio internacional en USD</span>
      </div>
    </div>

    <p class="nd-footnote">
      La caída ocurre sin guerras, sin sequías extraordinarias, sin colapso de la demanda mundial. Es estructural: el productor argentino recibe la mitad del precio que recibe el brasileño, y eso no cambia campaña tras campaña.
    </p>
  </div>
</div>

<script define:vars={{ chartData: data }}>
  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const existing = document.querySelector(`script[src="${src}"]`);
      if (existing) { existing.addEventListener('load', () => resolve()); if (existing.dataset.loaded) resolve(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => { s.dataset.loaded = 'true'; resolve(); };
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function loadDeps() {
    if (!window.Chart) {
      await loadScript('https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js');
    }
    if (!window['chartjs-plugin-annotation']) {
      await loadScript('https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js');
    }
    if (window['chartjs-plugin-annotation'] && window.Chart && !window.__annotationRegistered) {
      window.Chart.register(window['chartjs-plugin-annotation']);
      window.__annotationRegistered = true;
    }
  }

  function makeAnnotations() {
    const ann = {};
    chartData.anotaciones.forEach((a, i) => {
      ann[`mark${i}`] = {
        type: 'line',
        xMin: a.año,
        xMax: a.año,
        borderColor: '#c8392e',
        borderWidth: 1.2,
        borderDash: [3, 4],
        label: {
          display: true,
          content: a.label,
          position: 'start',
          backgroundColor: 'rgba(244, 234, 215, 0.95)',
          borderColor: '#c8392e',
          borderWidth: 1,
          color: '#2a1f15',
          font: { family: 'JetBrains Mono', size: 9, weight: '600' },
          padding: { top: 4, bottom: 4, left: 6, right: 6 },
          borderRadius: 2,
          yAdjust: -8 + i * 22,
        },
      };
    });
    return ann;
  }

  function initChart() {
    const canvas = document.getElementById('ndChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    new window.Chart(ctx, {
      type: 'line',
      data: {
        labels: chartData.años,
        datasets: [
          {
            label: 'Hectáreas plantadas',
            data: chartData.series.hectareas,
            borderColor: '#c8392e',
            backgroundColor: 'rgba(200, 57, 46, 0.08)',
            borderWidth: 2.5,
            tension: 0.3,
            fill: true,
            pointRadius: 0,
            pointHoverRadius: 6,
            pointHoverBackgroundColor: '#c8392e',
            pointHoverBorderColor: '#fff',
            pointHoverBorderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 1400, easing: 'easeOutQuart' },
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#2a1f15',
            titleFont: { family: 'JetBrains Mono', size: 11, weight: '600' },
            bodyFont: { family: 'Inter', size: 13 },
            padding: 12,
            cornerRadius: 4,
            callbacks: {
              label: (ctx) => ` ${ctx.parsed.y.toLocaleString('es-AR')} ha plantadas`,
            },
          },
          annotation: { annotations: makeAnnotations() },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { font: { family: 'JetBrains Mono', size: 11 }, color: '#6b5d4d', maxRotation: 0 },
            border: { color: '#d8cdb8' },
          },
          y: {
            grid: { color: 'rgba(216, 205, 184, 0.5)' },
            ticks: {
              font: { family: 'JetBrains Mono', size: 11 },
              color: '#6b5d4d',
              callback: (v) => (v / 1000).toFixed(0) + 'k ha',
            },
            border: { display: false },
          },
        },
      },
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const wrap = document.querySelector('.nd-wrap');
    if (!wrap) return;
    const start = () => loadDeps().then(initChart);
    if (!('IntersectionObserver' in window)) { start(); return; }
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { start(); obs.disconnect(); }
      });
    }, { threshold: 0.15 });
    obs.observe(wrap);
  });
</script>

<style>
  .nd-wrap {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }
  .nd-card {
    background: var(--paper-soft);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 2rem clamp(1.25rem, 3vw, 2.5rem);
  }
  .nd-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .nd-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.35rem;
    margin: 0 0 0.35rem 0;
    line-height: 1.2;
  }
  .nd-sub {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nd-headline-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }
  .nd-headline-num {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 2.4rem;
    line-height: 1;
    color: var(--ember);
    letter-spacing: -0.03em;
  }
  .nd-headline-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 0.35rem;
  }
  .nd-canvas-container {
    position: relative;
    height: 380px;
  }
  .nd-stats {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
  }
  .nd-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .nd-stat-num {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--ink-on-paper);
    letter-spacing: -0.02em;
  }
  .nd-stat:last-child .nd-stat-num { color: var(--gold); }
  .nd-stat-label {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nd-footnote {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
    font-family: var(--sans);
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.55;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .nd-canvas-container { height: 300px; }
    .nd-stats { grid-template-columns: 1fr; }
    .nd-headline-num { font-size: 1.9rem; }
  }
</style>
