---
interface Props {
  prevHref?: string;
  prevLabel?: string;
  current: string;
  nextHref?: string;
  nextLabel?: string;
}

const { prevHref, prevLabel, current, nextHref, nextLabel } = Astro.props;
---

<nav class="topnav">
  <div class="breadcrumb">
    {prevHref && prevLabel && <a href={prevHref}>← {prevLabel}</a>}
    {prevHref && <span class="sep">/</span>}
    <span class="current">{current}</span>
    {nextHref && <span class="sep">/</span>}
    {nextHref && nextLabel && <a href={nextHref}>{nextLabel} →</a>}
  </div>
  <span class="imprint">Del Pucho al Cigarrillo Electrónico</span>
</nav>

<style>
  .topnav {
    border-bottom: 1px solid var(--rule);
    padding: 1rem clamp(1.25rem, 4vw, 3rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ink-soft);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(244, 234, 215, 0.92);
    backdrop-filter: blur(6px);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--ink-soft);
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover { color: var(--ember); }
  .breadcrumb .current { color: var(--ink-on-paper); }
  .breadcrumb .sep { color: var(--ink-muted); }

  .imprint {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 0.85rem;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-soft);
  }

  @media (max-width: 768px) {
    .breadcrumb { font-size: 0.6rem; gap: 0.4rem; }
    .imprint { display: none; }
  }
</style>
