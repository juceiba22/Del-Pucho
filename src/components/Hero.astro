---
// Hero de la apertura (modo inmersión).
interface Props {
  kicker: string;
  headline: string;
  emphasis?: string;
  statNumber: string;
  statLabel: string;
}

const { kicker, headline, emphasis, statNumber, statLabel } = Astro.props;
const headlineHtml = emphasis ? headline.replace(emphasis, `<em>${emphasis}</em>`) : headline;
---

<section class="hero">
  <header class="top-bar">
    <span>Ibarra · Ediciones Agrotabaco · 2026</span>
    <span class="imprint">Del Pucho al Cigarrillo Electrónico</span>
  </header>

  <div class="hero-body">
    <div class="kicker">{kicker}</div>
    <h1 class="headline" set:html={headlineHtml} />
    <div class="stat-block">
      <div class="stat-number">{statNumber}</div>
      <div class="stat-label">
        <slot />
      </div>
    </div>
  </div>

  <div class="scroll-indicator">
    <span>▼</span>
    <span>Seguí leyendo</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 2.5rem clamp(1.5rem, 5vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 85% 15%, rgba(200, 57, 46, 0.10), transparent 65%),
      radial-gradient(ellipse 70% 50% at 10% 85%, rgba(200, 168, 73, 0.07), transparent 65%);
    pointer-events: none;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--ink-on-dark-soft);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    z-index: 1;
    position: relative;
  }

  .top-bar .imprint {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 0.95rem;
    color: var(--gold-soft);
    text-transform: none;
    letter-spacing: 0;
  }

  .hero-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 1100px;
    z-index: 1;
    position: relative;
    padding: 4rem 0;
  }

  .kicker {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--ember);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: hero-fade 0.9s ease-out 0.15s forwards;
  }

  .kicker::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--ember);
  }

  .headline {
    font-family: var(--serif);
    font-variation-settings: "SOFT" 0, "opsz" 144;
    font-weight: 400;
    font-size: clamp(2.75rem, 7.5vw, 7rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 0 0 3.5rem 0;
    max-width: 16ch;
    color: var(--ink);
    opacity: 0;
    animation: hero-fade-up 1.1s ease-out 0.3s forwards;
  }

  .headline :global(em) {
    font-style: italic;
    font-weight: 300;
    color: var(--gold-soft);
    font-variation-settings: "SOFT" 100, "opsz" 144;
  }

  .stat-block {
    display: grid;
    grid-template-columns: minmax(auto, 220px) 1fr;
    gap: 2.5rem 3rem;
    align-items: center;
    max-width: 880px;
    padding: 2.5rem 0;
    border-top: 1px solid var(--rule-on-dark);
    border-bottom: 1px solid var(--rule-on-dark);
    opacity: 0;
    animation: hero-fade-up 1.1s ease-out 0.6s forwards;
  }

  .stat-number {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(4rem, 8vw, 6.5rem);
    color: var(--ember);
    line-height: 1;
    letter-spacing: -0.04em;
    font-variation-settings: "SOFT" 0, "opsz" 144;
  }

  .stat-label {
    font-family: var(--sans);
    font-weight: 400;
    font-size: 1.05rem;
    color: var(--ink-on-dark-soft);
    line-height: 1.55;
  }

  .stat-label :global(strong) {
    color: var(--ink);
    font-weight: 500;
  }

  .stat-label :global(.accent) {
    color: var(--ember);
    font-weight: 500;
  }

  .scroll-indicator {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    color: var(--ink-on-dark-muted);
    text-transform: uppercase;
    z-index: 1;
    position: relative;
    padding-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    animation: hero-fade 0.9s ease-out 1.4s forwards, float 2.5s ease-in-out 2s infinite;
  }

  @keyframes hero-fade {
    to { opacity: 1; }
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50%      { transform: translateY(4px); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .kicker, .headline, .stat-block, .scroll-indicator {
      opacity: 1 !important;
      animation: none !important;
      transform: none !important;
    }
  }

  @media (max-width: 768px) {
    .stat-block {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .top-bar { gap: 1rem; }
    .top-bar > span:first-child { display: none; }
  }
</style>
