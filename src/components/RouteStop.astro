---
// Bloque reutilizable de una "parada" del recorrido.
// Acepta el objeto parada (con numero, kicker, titulo, actores, que_pasa, stats[], perdida)
// y un slot por defecto para la ilustración SVG.

interface Stat {
  valor: string;
  label: string;
}
interface Parada {
  id: string;
  numero: string;
  kicker: string;
  titulo: string;
  actores: string;
  que_pasa: string;
  stats: Stat[];
  perdida: string;
}

interface Props {
  parada: Parada;
  reverse?: boolean;
}

const { parada, reverse = false } = Astro.props;
---

<section id={`parada-${parada.id}`} class={`rs-stop reveal ${reverse ? 'is-reverse' : ''}`}>
  <div class="rs-inner">
    <div class="rs-visual">
      <div class="rs-svg-wrap">
        <slot />
      </div>
      <div class="rs-marker">
        <span class="rs-marker-num">{parada.numero}</span>
        <span class="rs-marker-label">de 06</span>
      </div>
    </div>

    <div class="rs-content">
      <span class="rs-kicker">Parada {parada.numero} · {parada.kicker}</span>
      <h3 class="rs-title">{parada.titulo}</h3>
      <p class="rs-actores">{parada.actores}</p>

      <p class="rs-prose">{parada.que_pasa}</p>

      <div class="rs-stats">
        {parada.stats.map(s => (
          <div class="rs-stat">
            <span class="rs-stat-num">{s.valor}</span>
            <span class="rs-stat-label">{s.label}</span>
          </div>
        ))}
      </div>

      <div class="rs-perdida">
        <span class="rs-perdida-label">Lo que se pierde aquí</span>
        <p class="rs-perdida-text">{parada.perdida}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .rs-stop {
    padding: 4rem clamp(1.25rem, 4vw, 2.5rem);
    border-top: 1px solid var(--rule);
  }
  .rs-stop:first-of-type {
    border-top: none;
  }

  .rs-inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .rs-stop.is-reverse .rs-inner {
    grid-template-columns: 1.2fr 1fr;
  }
  .rs-stop.is-reverse .rs-visual {
    order: 2;
  }

  /* VISUAL */
  .rs-visual {
    position: sticky;
    top: 88px;
    padding: 1rem;
    background: var(--paper-soft);
    border: 1px solid var(--rule);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .rs-svg-wrap {
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .rs-svg-wrap :global(svg) {
    width: 100%;
    height: 100%;
    max-width: 320px;
  }

  .rs-marker {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.85rem 1rem 0.6rem;
    border-top: 1px solid var(--rule);
  }
  .rs-marker-num {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 2.4rem;
    line-height: 1;
    color: var(--ember);
    letter-spacing: -0.03em;
  }
  .rs-marker-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--ink-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* CONTENT */
  .rs-content {
    min-width: 0;
  }
  .rs-kicker {
    display: block;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ember);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .rs-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    line-height: 1.05;
    margin: 0 0 0.5rem 0;
    color: var(--ink-on-paper);
    letter-spacing: -0.02em;
  }
  .rs-actores {
    margin: 0 0 1.5rem 0;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }
  .rs-prose {
    margin: 0 0 1.75rem 0;
    font-family: var(--sans);
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--ink-on-paper);
  }

  .rs-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 0 0 1.75rem 0;
    padding: 1.25rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .rs-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .rs-stat-num {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.4rem;
    line-height: 1.05;
    color: var(--ink-on-paper);
    letter-spacing: -0.02em;
  }
  .rs-stat-label {
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--ink-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  .rs-perdida {
    padding: 1.25rem 1.25rem 1.1rem;
    background: rgba(200, 57, 46, 0.06);
    border-left: 3px solid var(--ember);
    border-radius: 0 4px 4px 0;
  }
  .rs-perdida-label {
    display: block;
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--ember);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .rs-perdida-text {
    margin: 0;
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-on-paper);
  }

  @media (max-width: 900px) {
    .rs-inner,
    .rs-stop.is-reverse .rs-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .rs-stop.is-reverse .rs-visual {
      order: 0;
    }
    .rs-visual {
      position: static;
    }
    .rs-svg-wrap {
      padding: 0.5rem;
    }
  }
  @media (max-width: 560px) {
    .rs-stats { grid-template-columns: 1fr; gap: 0.85rem; }
  }
</style>
