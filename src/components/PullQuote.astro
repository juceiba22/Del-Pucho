---
interface Props {
  cite?: string;
}
const { cite } = Astro.props;
---

<div class="pullquote reveal">
  <q><slot /></q>
  {cite && <footer class="cite">{cite}</footer>}
</div>

<style>
  .pullquote {
    max-width: 1080px;
    margin: 5rem auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
    text-align: center;
    position: relative;
  }

  .pullquote::before {
    content: '"';
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(7rem, 12vw, 11rem);
    color: var(--ember);
    opacity: 0.22;
    line-height: 1;
    display: block;
    margin-bottom: -3rem;
  }

  q {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    line-height: 1.4;
    color: var(--ink-on-paper);
    letter-spacing: -0.005em;
    quotes: none;
  }

  q::before, q::after { content: ''; }

  .cite {
    margin-top: 1.5rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
</style>
