---
// Cita a pantalla completa en modo inmersión (apertura y cierre).
interface Props {
  signature?: string;
}
const { signature } = Astro.props;
---

<section class="quote-section">
  <div class="quote-container">
    <div class="quote-mark">"</div>
    <blockquote class="reveal">
      <slot />
      {signature && <span class="signature">{signature}</span>}
    </blockquote>
  </div>
</section>

<style>
  .quote-section {
    min-height: 95vh;
    display: grid;
    place-items: center;
    padding: 6rem clamp(1.5rem, 5vw, 4rem);
    background: var(--bg-warm);
    position: relative;
    overflow: hidden;
  }

  .quote-section::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 1px;
    background: var(--gold-soft);
    opacity: 0.4;
  }

  .quote-container {
    max-width: 920px;
    position: relative;
    text-align: center;
  }

  .quote-mark {
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(8rem, 14vw, 14rem);
    color: var(--gold-soft);
    line-height: 1;
    opacity: 0.35;
    margin-bottom: -2.5rem;
  }

  blockquote {
    margin: 0;
    font-family: var(--serif);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.4rem, 2.8vw, 2.1rem);
    line-height: 1.4;
    color: var(--ink);
    letter-spacing: -0.005em;
  }

  blockquote :global(em) {
    font-style: italic;
    color: var(--gold-soft);
  }

  .signature {
    display: block;
    margin-top: 3rem;
    font-family: var(--mono);
    font-style: normal;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-soft);
  }

  .signature::before {
    content: '— ';
  }
</style>
